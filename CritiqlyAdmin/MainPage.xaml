<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CritiqlyAdmin.MainPage"
             Title="Critiqly Nexus Core"
             Shell.BackgroundColor="#1C1A15"
             Shell.NavBarIsVisible="False"
             xmlns:Models="clr-namespace:CritiqlyAdmin.Models">

    <VerticalStackLayout>
        <HorizontalStackLayout VerticalOptions="Fill">
            <Label
             Text="Critiqly Nexus Core"
             FontFamily="Kimberley"
             TextColor="#D4FF3E"
             VerticalTextAlignment="Center"
             VerticalOptions="Center"
             HeightRequest="50"
             FontSize="40"
             Margin="30,20,0,0"/>

            <Button 
            Margin="400,20,5,0"
            Clicked="GetMovies"
            x:Name="getMoviesBtn"
            BackgroundColor="Red"
            Text="FILMEK LEKÉRÉSE"
            FontFamily="Kimberley"
            TextColor="White"/>
            
            <Button 
            Margin="5,20,5,0"
            Clicked="GetRatings"
            x:Name="getRatingsBtn"
            BackgroundColor="red" 
            Text="ÉRTÉKELÉSEK LEKÉRÉSE"
            FontFamily="Kimberley"
            TextColor="White"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout VerticalOptions="Fill" HorizontalOptions="Center" Margin="0,50,0,0">
            <Button 
                Margin="5,0,5,0" 
                Clicked="TestDailyMovies"
                BackgroundColor="#D4FF3E"
                Text="NAPI FILMEK KIVÁLASZTÁSA"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="selectDailyBtn"/>
            
            <Button 
                Margin="5,0,5,0"
                Clicked="GetTrendingMovies"
                BackgroundColor="#D4FF3E"
                Text="FELKAPOTT FILMEK FRISSÍTÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="updateTrendingBtn"/>

            <Button 
                Margin="5,0,5,0" 
                Clicked="GetTrendingMovies"
                BackgroundColor="#D4FF3E"
                Text="FILMEK SZERKESZTÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="updateMoviesBtn"/>

            <Button 
                Margin="5,0,5,0" 
                Clicked="GetTrendingMovies"
                BackgroundColor="#D4FF3E"
                Text="FILMEK TÖRLÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="deleteMoviesBtn"/>
        </HorizontalStackLayout>
        
        <CollectionView ItemsSource="{Binding Movies}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="Models:Movie">
                    <Grid Padding="10">
                        <Label Text="{Binding title}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
