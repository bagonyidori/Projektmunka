<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CritiqlyAdmin.UpdateMovieSubPage"
             Title="UpdateMovieSubPage">
    <VerticalStackLayout>
        <HorizontalStackLayout 
            VerticalOptions="Fill" 
            BackgroundColor="#2A2720">
            <Image 
                Source='Images/critiqlyNexusCore.png'
                MaximumHeightRequest="50"
                Margin="30,30,0,0"
                VerticalOptions="Center"
                HorizontalOptions="Center">
            </Image>
            <Button 
            Margin="500,20,5,0"
            Clicked="Exit"
            x:Name="exitBtn"
            BackgroundColor="OrangeRed" 
            Text="KILÉPÉS"
            FontFamily="Kimberley"
            TextColor="White"
            MinimumWidthRequest="200"/>

            <Button 
            Margin="5,20,5,25"
            Clicked="Save"
            x:Name="SaveBtn"
            BackgroundColor="Red" 
            Text="MENTÉS ÉS KILÉPÉS"
            FontFamily="Kimberley"
            TextColor="White"
            MinimumWidthRequest="200"/>
        </HorizontalStackLayout>

            <Border 
                BackgroundColor="#F5F5F5"
                Stroke="#D4FF3E"
                StrokeThickness="5"
                StrokeShape="RoundRectangle 10"
                WidthRequest="250"
                MaximumHeightRequest="550"
                >
                <Grid 
                    RowDefinitions="*,*,3*,*,*"
                    ColumnDefinitions="Auto,Auto"
                    BackgroundColor="#1C1A15"
                    >
                    <Label
                        x:Name="LabelTitle"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="0"
                        Grid.Column="0"/>
                    <Label 
                        x:Name="LabelGenre"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="1"/>
                    <Label
                        x:Name="LabelPlot"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="2"
                        Grid.Column="0"/>
                    <Label
                        x:Name="LabelDate"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="3"
                        Grid.Column="0"/>
                    <Label
                        x:Name="LabelPoster"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="4"
                        Grid.Column="0"/>

                    <Entry
                        Placeholder="Új cím?"
                        FontFamily="Kimberley"
                        TextColor="White"
                        PlaceholderColor="#828282"
                        BackgroundColor="#1C1A15"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Start"
                        x:Name="EntryTitle"
                        Grid.Row="0"
                        Grid.Column="1"/>
                    <Entry
                        Placeholder="Új műfaj?"
                        FontFamily="Kimberley"
                        TextColor="White"
                        PlaceholderColor="#828282"
                        BackgroundColor="#1C1A15"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Start"
                        x:Name="EntryGenre"
                        Grid.Row="1"
                        Grid.Column="1"/>
                    <Entry
                        Placeholder="Új leírás?"
                        FontFamily="Kimberley"
                        TextColor="White"
                        PlaceholderColor="#828282"
                        BackgroundColor="#1C1A15"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Start"
                        x:Name="EntryPlot"
                        Grid.Row="2"
                        Grid.Column="1"/>
                    <Entry
                        Placeholder="Új megjelenési dátum?"
                        FontFamily="Kimberley"
                        TextColor="White"
                        PlaceholderColor="#828282"
                        BackgroundColor="#1C1A15"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Start"
                        x:Name="EntryDate"
                        Grid.Row="3"
                        Grid.Column="1"/>
                    <Entry
                        Placeholder="Új poster link?"
                        FontFamily="Kimberley"
                        TextColor="White"
                        PlaceholderColor="#828282"
                        BackgroundColor="#1C1A15"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Start"
                        x:Name="EntryPoster"
                        Grid.Row="4"
                        Grid.Column="1"/>
                </Grid>
            </Border>
    </VerticalStackLayout>
</ContentPage>